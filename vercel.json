{
  "name": "shoredrop",
  "public": true,
  "rewrites": [
    { "source": "/api/webhook", "destination": "/api/webhook.js" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
