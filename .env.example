# Shore Drop — Environment Variables
# Copy this to .env and fill in your values

# Stripe keys — get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx   # from Stripe Webhooks dashboard

# SendGrid — free at sendgrid.com (100 emails/day free)
# OR use Resend.com (3000 emails/month free) — just update server.js API call
SENDGRID_API_KEY=SG.xxxxx

# Server (for local webhook testing)
PORT=3001
